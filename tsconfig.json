{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "react", "react-dom"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "frontend/src/**/*", "vite.config.ts"]
}
